# A3 Cargo — environment variables
# Copy to .env and fill in real values before running docker compose up.
#
#   cp .env.example .env
#   printf 'JWT_SECRET=%s\nADMIN_KEY=%s\n' "$(openssl rand -hex 32)" "$(openssl rand -hex 16)" > .env

JWT_SECRET=change_me_use_openssl_rand_hex_32
ADMIN_KEY=change_me_use_openssl_rand_hex_16
